# ════════════════════════════════════════════════════════════════
# Frontfiles — environment variable example
#
# Copy to `.env.local` for development. Never commit `.env.local`.
# Production / preview values live in the Vercel project settings.
#
# Source of truth for the schema is `src/lib/env.ts` (Zod-validated
# at boot, fail-fast). Keys flagged "Required" must be present or
# the app will refuse to start. Keys flagged "Optional" can stay
# empty until the feature that needs them is wired.
# ════════════════════════════════════════════════════════════════

# ─── Required: Supabase foundation ──────────────────────────────
# Project URL — find in Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Public anon key — safe in the browser bundle (RLS is the boundary).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER-ONLY. Bypasses RLS. Never reach this from
# `src/app/` or `src/components/` (the lint rule in eslint.config.mjs
# blocks literal references). Use `getSupabaseClient()` in API routes.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Required: App URL ──────────────────────────────────────────
# Public-facing URL for this deployment. Used in email links and
# OAuth callbacks. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Feature flags ──────────────────────────────────────────────
# All flags are string "true" / "false" (Zod enum). Default false.

# Gates the FFF broadcast surface visibility. Default false (v1
# is broadcast-only; UI surfaces are hidden until lock).
NEXT_PUBLIC_FFF_SHARING_ENABLED=false

# Gates the real /api/upload commit path. `false` returns 503.
FFF_REAL_UPLOAD=false

# Gates the spec-canonical request surface (requireActor + the 13
# retiring routes' replacements). After concern 4A.2.AUTH (this
# concern):
#   - Set FFF_AUTH_WIRED=true in dev/staging to enable real
#     authentication: `/signin` then submits to Supabase Auth and
#     `POST /api/auth/ensure-actor-handle` provisions the actor row.
#   - With the flag off, every auth-wired route 404s and `/signin`
#     still renders but submitting will surface the generic error.
#   - Production cutover at P5 is a separate change.
FFF_AUTH_WIRED=false

# Gates the spec-canonical replacement pages (offer / assignment /
# dispute surfaces). Server-only; checked in page.tsx server
# components via isEconomicV1UiEnabled(). Flipped true at 4B
# alongside FFF_AUTH_WIRED.
FFF_ECONOMIC_V1_UI=false

# Storage adapter selection: `fs` (local filesystem) or `supabase`.
# Default `fs` for dev simplicity.
FFF_STORAGE_DRIVER=fs
# Local filesystem root when FFF_STORAGE_DRIVER=fs. Defaults to
# ./public/dev/uploads.
FFF_STORAGE_FS_ROOT=
# Supabase Storage bucket name when FFF_STORAGE_DRIVER=supabase.
FFF_STORAGE_SUPABASE_BUCKET=

# ─── Optional: Stripe (wired in Phase 5) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Optional: Google / Vertex AI (wired in Phase 4) ────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# Default Vertex AI region when creator ai_region is not set.
# EU default per D8.
VERTEX_AI_LOCATION=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ─── Optional: Apple Sign In (wired in Phase 4.A) ───────────────
APPLE_SIGN_IN_TEAM_ID=
APPLE_SIGN_IN_CLIENT_ID=
APPLE_SIGN_IN_KEY_ID=
APPLE_SIGN_IN_PRIVATE_KEY=

# ─── Optional: Resend (wired in Phase 3) ────────────────────────
RESEND_API_KEY_TRANSACTIONAL=
RESEND_API_KEY_MARKETING=
# e.g. "Frontfiles <hello@mail.frontfiles.news>"
RESEND_FROM_TRANSACTIONAL=
# e.g. "Frontfiles <news@news.frontfiles.news>"
RESEND_FROM_MARKETING=

# ─── Optional: Observability (wired in Phase 2) ─────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─── Node runtime ───────────────────────────────────────────────
# Set automatically by `next dev` / `next build` / vitest. Override
# only for unusual deploy targets.
# NODE_ENV=development
