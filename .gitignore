# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# dev artifacts — watermark drafts, scratch outputs, dev-only rendering
/public/dev/

# macOS finder clutter (beyond the .DS_Store above)
._*

# editor / IDE scratch
.vscode/
.idea/

# Large binary video assets — exceed GitHub's 100MB file limit.
# Store externally (Vercel Blob, Cloudflare R2, S3) when referenced
# from production code. Note: this rule does NOT affect the 11 video
# files already tracked from before 2026-04-17 — gitignore only applies
# to untracked paths. Those existing files remain where they are.
/public/assets/videos/*.mp4
/public/assets/videos/*.mov
*.tsbuildinfo*
